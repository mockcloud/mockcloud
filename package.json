{
  "name": "mockcloud",
  "version": "2.0.0",
  "description": "MockCloud — Free, open-source local AWS emulator. No account. No token. MIT licensed. (Go implementation)",
  "type": "module",
  "bin": {
    "mockcloud": "bin/mockcloud.js"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/mockcloud.js",
    "build": "npm run ui:build && go build -tags embedui -o bin/mockcloud ./cmd/mockcloud",
    "test": "node scripts/conformance.mjs --all --strict",
    "conformance": "node scripts/conformance.mjs",
    "ui:dev": "cd ui && npm run dev",
    "ui:build": "cd ui && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": {
    "name": "Pranjal Bareth",
    "url": "https://github.com/pranjalbareth"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mockcloud/mockcloud"
  },
  "homepage": "https://github.com/mockcloud/mockcloud",
  "bugs": {
    "url": "https://github.com/mockcloud/mockcloud/issues"
  },
  "keywords": [
    "aws",
    "aws-emulator",
    "localstack",
    "mock",
    "cloud",
    "serverless",
    "testing",
    "offline",
    "golang"
  ],
  "comment:optionalDependencies": "At publish time (docs/MIGRATION.md §Release) the release pipeline adds @mockcloud/cli-<os>-<arch> platform packages here so `npx mockcloud` fetches the matching prebuilt binary (esbuild pattern). Omitted from the repo so `npm install` stays clean before those packages are published.",
  "devDependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1045.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1045.0",
    "@aws-sdk/client-dynamodb": "^3.1045.0",
    "@aws-sdk/client-ec2": "^3.1045.0",
    "@aws-sdk/client-lambda": "^3.1045.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/client-sns": "^3.1045.0",
    "@aws-sdk/client-sqs": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "vitest": "^3.0.0"
  }
}
