{
  "name": "mockcloud",
  "version": "1.2.1",
  "description": "MockCloud — Free, open-source local AWS emulator. No account. No token. MIT licensed.",
  "main": "src/index.js",
  "type": "module",
  "files": [
    "src",
    "scripts",
    "ui/dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "reset": "node scripts/reset.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "ui:dev": "cd ui && npm run dev",
    "ui:build": "cd ui && npm run build",
    "prepack": "cd ui && npm ci && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": {
    "name": "Pranjal Bareth",
    "url": "https://github.com/pranjalbareth"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mockcloud/mockcloud"
  },
  "homepage": "https://github.com/mockcloud/mockcloud",
  "bugs": {
    "url": "https://github.com/mockcloud/mockcloud/issues"
  },
  "keywords": [
    "aws",
    "aws-emulator",
    "localstack",
    "mock",
    "cloud",
    "serverless",
    "testing",
    "offline"
  ],
  "devDependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1045.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1045.0",
    "@aws-sdk/client-dynamodb": "^3.1045.0",
    "@aws-sdk/client-ec2": "^3.1045.0",
    "@aws-sdk/client-lambda": "^3.1045.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/client-sns": "^3.1045.0",
    "@aws-sdk/client-sqs": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "vitest": "^3.0.0"
  }
}