{
  "name": "mockcloud",
  "version": "1.2.1",
  "description": "MockCloud — Free, open-source local AWS emulator. No account. No token. MIT licensed.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "reset": "node scripts/reset.js",
    "test": "node --test tests/ec2.test.js tests/s3.test.js tests/apigatewayv2.test.js tests/dynamodb.test.js tests/sqs.test.js tests/sns.test.js tests/lambda.test.js tests/kms.test.js tests/ssm.test.js tests/store.test.js",
    "test:watch": "node --test --watch tests/*.test.js",
    "ui:dev": "cd ui && npm run dev",
    "ui:build": "cd ui && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": {
    "name": "Pranjal Bareth",
    "url": "https://github.com/pranjalbareth"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mockcloud/mockcloud"
  },
  "homepage": "https://github.com/mockcloud/mockcloud",
  "bugs": {
    "url": "https://github.com/mockcloud/mockcloud/issues"
  },
  "keywords": [
    "aws",
    "aws-emulator",
    "localstack",
    "mock",
    "cloud",
    "serverless",
    "testing",
    "offline"
  ],
  "devDependencies": {
    "@aws-sdk/client-api-gateway": "^3.1045.0",
    "@aws-sdk/client-apigatewayv2": "^3.1045.0",
    "@aws-sdk/client-ec2": "^3.1045.0",
    "@aws-sdk/client-s3": "^3.1045.0"
  }
}